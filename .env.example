# Copy this file to .env and fill in your API keys.
# The .env file is loaded automatically by both start_webui.command and webui.py.
# Values here do NOT overwrite keys already set in the shell environment.

# --- Gemini (Google AI) ---
# Used for AI summaries (gemini-1.5-flash) and TTS (gemini-2.5-flash-preview-tts).
GEMINI_API_KEY=

# Alternative name accepted by some Google SDK versions:
# GOOGLE_API_KEY=

# --- OpenAI ---
# Used for AI summaries when the OpenAI provider is selected.
OPENAI_API_KEY=

# --- ElevenLabs ---
# Used for high-quality text-to-speech audio generation.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
